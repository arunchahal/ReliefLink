# Relieflink Frontend Environment Variables Example
# Copy this file to '.env' in this directory and modify values as needed.

# The URL of your Flask backend deployment (e.g. on Render, Heroku, etc.)
# If left blank, it automatically falls back to http://127.0.0.1:5001 in local development (npm run dev)
VITE_API_BASE_URL=https://your-deployed-backend-url.onrender.com
